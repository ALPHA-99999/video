####### Install

install_target: first FORCE
	@if not exist $(INSTALL_ROOT)\bin mkdir $(INSTALL_ROOT)\bin & if not exist $(INSTALL_ROOT)\bin exit 1
	-$(INSTALL_FILE) $(DESTDIR_TARGET) $(INSTALL_ROOT)\bin\$(TARGET)
	-$(INSTALL_FILE) debug\untitled.pdb $(INSTALL_ROOT)\bin\untitled.pdb

uninstall_target: FORCE
	-$(DEL_FILE) $(INSTALL_ROOT)\bin\$(TARGET) 
	 -$(DEL_FILE) $(INSTALL_ROOT)\bin\untitled.pdb
	-$(DEL_DIR) $(INSTALL_ROOT)\bin 


